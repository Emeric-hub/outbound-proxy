# Elastic stack version — keep all three images in sync
ELASTIC_VERSION=8.13.0

# ── Elasticsearch / Kibana credentials ───────────────────────────────────────
# ELASTIC_PASSWORD: password for the built-in 'elastic' superuser.
#   Used internally by Kibana and Filebeat to connect to Elasticsearch.
#   Changing this after first boot requires deleting the es-data volume.
# KIBANA_USER / KIBANA_PASSWORD: admin account for the Kibana UI.
#   Updated automatically every time kibana-init runs.
ELASTIC_PASSWORD=changeme
KIBANA_USER=admin
KIBANA_SERVICE_TOKEN=changeme

# E2Guardian image tag (arch-specific: v5.6-amd64 or v5.6-arm)
E2GUARDIAN_VERSION=v5.6-amd64

# ── Squid cache ───────────────────────────────────────────────────────────────
# RAM cache for small objects (cache_mem). Unit: MB.
# Disk cache size is managed by Squid's defaults (adding cache_dir here
# triggers a known Squid 6.13 xcalloc crash, so it is left to the image).
SQUID_CACHE_SIZE=256

# ── E2Guardian filter toggles ─────────────────────────────────────────────────
# Values: "on" or "off". A container restart is required after changing these.
E2G_CONTENT_FILTER=on   # Phrase-based scoring (profanity, violence, adult content…)
E2G_SITE_BLOCK=on       # Banned site list (e2guardian/lists/bannedsitelist)
E2G_SSL_MITM=on         # HTTPS MITM inspection (CA cert must be trusted by clients)
E2G_BYPASS=on          # Let users bypass individual blocks via a browser prompt
